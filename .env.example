# Telegram Bot
BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/veriaapp

# Webhook (production)
USE_WEBHOOK=false
WEBHOOK_DOMAIN=https://veria.dalivand.com
